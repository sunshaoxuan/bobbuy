# ====================================================================
# BOBBuy trial deployment environment template
# Copy this file to `.env` before running `docker compose`.
# Priority: environment variables > Nacos config > application-{profile}.properties > application.properties
# ====================================================================

# --------------------------------------------------------------------
# PostgreSQL / Flyway
# Local-only default below must be changed before any shared/server deployment.
# Compose keeps Flyway execution on core-service only.
# --------------------------------------------------------------------
POSTGRES_DB=bobbuy
POSTGRES_USER=bobbuy
POSTGRES_PASSWORD=bobbuypassword
POSTGRES_HOST_PORT=5432
BOBBUY_FLYWAY_BASELINE_ON_MIGRATE=false

# --------------------------------------------------------------------
# JWT / header auth / seed data
# `BOBBUY_SECURITY_JWT_SECRET` is REQUIRED for any trial/public deployment.
# Example generation command: `openssl rand -base64 32`
# Leaving it empty will cause backend startup failure by design.
# Never enable header auth on public/shared networks.
# WebSocket `/ws` reuses the same access token via STOMP CONNECT header.
# `BOBBUY_SECURITY_SERVICE_TOKEN` is REQUIRED once gateway/internal service
# calls are enabled in trial deployment. Generate it separately from JWT secret.
# Access token and refresh token are both enabled in trial mode.
# Refresh token remains stored on the server as hash only, is delivered via
# HttpOnly SameSite cookie, and rotates on refresh.
# Frontend now keeps access token / user profile / expiry metadata in
# localStorage, but no longer persists the refresh token itself.
# `BOBBUY_SECURITY_REFRESH_COOKIE_SECURE` must be true for public HTTPS deploys.
# Demo seed credentials are for local bootstrap only.
# --------------------------------------------------------------------
BOBBUY_SECURITY_JWT_SECRET=
BOBBUY_SECURITY_JWT_TTL_SECONDS=3600
BOBBUY_SECURITY_REFRESH_TOKEN_TTL_SECONDS=604800
BOBBUY_SECURITY_REFRESH_TOKEN_ROTATION_ENABLED=true
BOBBUY_SECURITY_REFRESH_COOKIE_NAME=bobbuy_refresh_token
BOBBUY_SECURITY_REFRESH_COOKIE_PATH=/api/auth
BOBBUY_SECURITY_REFRESH_COOKIE_SECURE=false
BOBBUY_SECURITY_REFRESH_COOKIE_SAME_SITE=Lax
BOBBUY_SECURITY_CSRF_COOKIE_NAME=bobbuy_csrf_token
BOBBUY_SECURITY_CSRF_COOKIE_PATH=/
BOBBUY_SECURITY_CSRF_HEADER_NAME=X-BOBBUY-CSRF-TOKEN
BOBBUY_SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost,http://127.0.0.1,http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173
BOBBUY_SECURITY_HEADER_AUTH_ENABLED=false
BOBBUY_SECURITY_SERVICE_TOKEN=
BOBBUY_SEED_ENABLED=false

# --------------------------------------------------------------------
# MinIO
# Root credentials below are local-only defaults and must be changed before
# any shared/server deployment.
# --------------------------------------------------------------------
MINIO_ROOT_USER=bobbuyadmin
MINIO_ROOT_PASSWORD=bobbuypassword
BOBBUY_MINIO_BUCKET=bobbuy-media
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# --------------------------------------------------------------------
# Redis / RabbitMQ
# RabbitMQ credentials below are local-only defaults and must be changed before
# any shared/server deployment.
# --------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=bobbuy
RABBITMQ_DEFAULT_PASS=bobbuypassword
REDIS_PASSWORD=

# --------------------------------------------------------------------
# Nacos
# `NACOS_SERVER_ADDR` is the in-cluster service address used by containers.
# `NACOS_HOST_PORT` only controls optional localhost console access.
# --------------------------------------------------------------------
NACOS_SERVER_ADDR=nacos:8848
NACOS_HOST_PORT=8848

# --------------------------------------------------------------------
# AI LLM / OCR
# Server deployment should prefer Ollama or a private compatible gateway.
# `codex-bridge` is an OpenAI-compatible `/v1/chat/completions` gateway for a
# privately managed Codex subscription bridge. Do not commit a plaintext key.
# If encrypted key fields are committed, keep BOBBUY_AI_SECRET_MASTER_PASSWORD
# outside git in the host environment or secret manager.
# Leave Codex CLI blank unless this is a local desktop environment with an
# explicitly managed Codex login session.
# Leaving MAIN_URL / EDGE_URL / OCR_URL blank is supported; runtime trace will
# report `unconfigured` and the UI will fall back to retry/manual review flows.
# --------------------------------------------------------------------
BOBBUY_AI_LLM_MAIN_PROVIDER=auto
BOBBUY_AI_LLM_MAIN_URL=
BOBBUY_AI_LLM_MAIN_MODEL=qwen2.5:7b
BOBBUY_AI_LLM_CODEX_COMMAND=
BOBBUY_AI_LLM_CODEX_TIMEOUT_SECONDS=120
BOBBUY_AI_LLM_CODEX_BRIDGE_URL=
BOBBUY_AI_LLM_CODEX_BRIDGE_MODEL=gpt-5.3-codex
BOBBUY_AI_LLM_CODEX_BRIDGE_API_KEY=
BOBBUY_AI_LLM_CODEX_BRIDGE_TIMEOUT_SECONDS=120
BOBBUY_AI_LLM_CODEX_BRIDGE_SECRET_SALT=
BOBBUY_AI_LLM_CODEX_BRIDGE_SECRET_NONCE=
BOBBUY_AI_LLM_CODEX_BRIDGE_SECRET_CIPHERTEXT=
BOBBUY_AI_LLM_CODEX_BRIDGE_SECRET_TAG=
BOBBUY_AI_LLM_CODEX_BRIDGE_SECRET_ITERATIONS=200000
BOBBUY_AI_SECRET_MASTER_PASSWORD=
BOBBUY_AI_LLM_OLLAMA_HEALTH_TIMEOUT_SECONDS=3
BOBBUY_AI_LLM_EDGE_URL=
BOBBUY_AI_LLM_EDGE_MODEL=llama3.2-vision:11b
BOBBUY_OCR_URL=http://ocr-service:8000
OCR_HOST_PORT=8000

# --------------------------------------------------------------------
# Frontend / gateway host ports
# Host bindings default to localhost only to avoid accidental public exposure.
# --------------------------------------------------------------------
BOBBUY_BIND_HOST=127.0.0.1
GATEWAY_HOST_PORT=80
