# ====================================================================
# BOBBuy Production Environment Variables
# ====================================================================

# 1. Database (PostgreSQL)
POSTGRES_DB=bobbuy
POSTGRES_USER=bobbuy
POSTGRES_PASSWORD=bobbuypassword

# 2. Object Storage (MinIO)
MINIO_ROOT_USER=bobbuyadmin
MINIO_ROOT_PASSWORD=bobbuypassword
MINIO_DEFAULT_BUCKETS=bobbuy-media

# 3. Message Queue (RabbitMQ)
RABBITMQ_DEFAULT_USER=bobbuy
RABBITMQ_DEFAULT_PASS=bobbuypassword

# 4. Cache (Redis)
REDIS_PASSWORD=

# 5. Backend Configuration
SPRING_PROFILES_ACTIVE=prod
BOBBUY_SEED_ENABLED=false
BOBBUY_MINIO_ENDPOINT=http://minio:9000

# 6. AI Hermes Orchestration
# Set to your production LLM gateway
BOBBUY_AI_LLM_MAIN_URL=http://ccnode.briconbric.com:22545
BOBBUY_AI_LLM_EDGE_URL=http://192.168.20.218:11434
